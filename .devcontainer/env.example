SSH_KEY_PATH=/Users/xxx/.ssh/id_ed25519
GH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 容器走宿主代理（codex 需访问 chatgpt.com）。host.docker.internal=宿主。
# 端口改成本机代理实际的 HTTP 入站端口（Clash 默认 7897；Trojan-Qt5 看其设置）。
# 宿主代理必须监听 0.0.0.0，否则容器连不进来。
HTTP_PROXY=http://host.docker.internal:7897
HTTPS_PROXY=http://host.docker.internal:7897
http_proxy=http://host.docker.internal:7897
https_proxy=http://host.docker.internal:7897
NO_PROXY=localhost,127.0.0.1,::1,.local
no_proxy=localhost,127.0.0.1,::1,.local
