# 镜像构建只需要 .agent/harness/install-tools.sh，其余都排除以加速构建、避免泄密。

# 依赖与构建产物（最大头）
node_modules
dist
dist-ssr

# 版本控制与 CI
.git
.github

# 密钥 / 环境变量（绝不进 build context）
.env
.env.*
*.local

# 容器相关备份与本机配置
.devcontainer-back
.claude
.idea
.vscode

# 日志
logs
*.log

# 系统与杂项
.DS_Store
.playwright-cli

# 文档（构建用不到）
*.md
